#!/usr/bin/env python3
import argparse
import hashlib
import os
import re
import shutil
import subprocess
import sys
from pathlib import Path
from string import Template

SERVICE_NAME = "dev"
CONTAINER_USER = "guest"
CONTAINER_HOME = "/home/guest"

BASE_DIR = Path(__file__).resolve().parent
PROJECT_ROOT = BASE_DIR.parent
COMPOSE_FILE = BASE_DIR / "compose.yaml"
BASE_IMAGE_DIR = BASE_DIR / "base"
STATE_DIR = BASE_DIR / ".saturn"
BASE_HASH_FILE = STATE_DIR / "base-hash"
MODE_FILE = STATE_DIR / "mode"

MARKER_START = re.compile(r"^\s*#\s*saturn-dual-mode\s+start\s*$")
MARKER_END = re.compile(r"^\s*#\s*saturn-dual-mode\s+end\s*$")
VOLUME_ENTRY = re.compile(
    r"^\s*-\s*(?P<host>[^:\s]+):(?P<container>[^:\s]+)(?::(?P<opts>\S+))?\s*$"
)


def fail(msg, code=1):
    print(f"saturn: {msg}", file=sys.stderr)
    raise SystemExit(code)


def detect_compose():
    docker = shutil.which("docker")
    if docker is None:
        fail("docker is required but was not found in PATH")
    try:
        subprocess.run(
            [docker, "compose", "version"],
            check=True, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
        )
        return [docker, "compose"]
    except (subprocess.CalledProcessError, FileNotFoundError):
        pass
    dc = shutil.which("docker-compose")
    if dc is None:
        fail("docker compose is required (install docker compose v2 or docker-compose)")
    return [dc]


COMPOSE_CMD = detect_compose()


def current_level():
    try:
        return int(os.environ.get("SATURN_LEVEL", "0"))
    except ValueError:
        return 0


def project_name():
    return PROJECT_ROOT.name


def workspace_hash():
    return hashlib.sha256(str(PROJECT_ROOT).encode()).hexdigest()[:8]


def compose_project_name():
    sanitized = re.sub(r"[^a-z0-9-]+", "-", project_name().lower()).strip("-") or "saturn"
    return f"{sanitized}-{workspace_hash()}"


def runtime_env(base_tag):
    env = os.environ.copy()
    env["DEV_UID"] = str(os.getuid())
    env["DEV_GID"] = str(os.getgid())
    env["DEV_USER"] = CONTAINER_USER
    env["DEV_PROJECT_NAME"] = project_name()
    env["SATURN_LEVEL"] = str(current_level() + 1)
    env["COMPOSE_PROJECT_NAME"] = compose_project_name()
    env["SATURN_BASE_TAG"] = base_tag
    return env


def base_hash():
    h = hashlib.sha256()
    for name in sorted(os.listdir(BASE_IMAGE_DIR)):
        p = BASE_IMAGE_DIR / name
        if p.is_file():
            h.update(name.encode())
            h.update(b"\0")
            h.update(p.read_bytes())
    return h.hexdigest()[:12]


def ensure_base():
    tag = base_hash()
    cached = BASE_HASH_FILE.read_text().strip() if BASE_HASH_FILE.exists() else ""
    need_build = True
    if cached == tag:
        r = subprocess.run(
            ["docker", "image", "inspect", f"saturn-base:{tag}"],
            stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
        )
        need_build = r.returncode != 0
    if need_build:
        subprocess.run(
            ["docker", "build", "-t", f"saturn-base:{tag}", str(BASE_IMAGE_DIR)],
            check=True,
        )
        STATE_DIR.mkdir(exist_ok=True)
        BASE_HASH_FILE.write_text(tag)
    return tag


def parse_marker_block(text, env):
    entries = []
    in_block = False
    for line in text.splitlines():
        if MARKER_START.match(line):
            in_block = True
            continue
        if MARKER_END.match(line):
            in_block = False
            continue
        if in_block:
            m = VOLUME_ENTRY.match(line)
            if not m:
                continue
            host = Template(m.group("host")).safe_substitute(env)
            container = Template(m.group("container")).safe_substitute(env)
            if host == '..':
                continue
            entries.append((host, container))
    return entries


def transform_compose(text, mode):
    out = []
    in_block = False
    for line in text.splitlines():
        if MARKER_START.match(line):
            in_block = True
            continue
        if MARKER_END.match(line):
            in_block = False
            continue
        if in_block and mode == "copy" and VOLUME_ENTRY.match(line):
            continue
        out.append(line)
    return "\n".join(out) + "\n"


def compose_stdin(mode):
    return transform_compose(COMPOSE_FILE.read_text(), mode)


def compose_run(args, mode, base_tag, check=True, stdin_text=None):
    if stdin_text is None:
        stdin_text = compose_stdin(mode)
    return subprocess.run(
        [*COMPOSE_CMD, "-f", "-", *args],
        cwd=BASE_DIR,
        env=runtime_env(base_tag),
        input=stdin_text,
        text=True,
        check=check,
    )


def container_id():
    r = subprocess.run(
        ["docker", "ps", "-q",
         "--filter", f"label=com.docker.compose.project={compose_project_name()}",
         "--filter", f"label=com.docker.compose.service={SERVICE_NAME}"],
        capture_output=True, text=True, check=False,
    )
    if r.returncode != 0:
        return ""
    ids = r.stdout.strip().splitlines()
    return ids[0] if ids else ""


def save_mode(mode):
    STATE_DIR.mkdir(exist_ok=True)
    MODE_FILE.write_text(mode)


def load_mode():
    return MODE_FILE.read_text().strip() if MODE_FILE.exists() else ""


def clear_mode():
    if MODE_FILE.exists():
        MODE_FILE.unlink()


def resolve_host(path):
    p = Path(os.path.expanduser(path))
    if not p.is_absolute():
        p = (BASE_DIR / p).resolve()
    return p


def copy_in(entries):
    cid = container_id()
    if not cid:
        fail("container not running")
    for host, container in entries:
        hp = resolve_host(host)
        if not hp.exists():
            print(f"saturn: skipping copy-in (missing on host): {hp}", file=sys.stderr)
            continue
        parent = os.path.dirname(container.rstrip("/")) or "/"
        subprocess.run(["docker", "exec", cid, "mkdir", "-p", parent], check=True)
        subprocess.run(["docker", "cp", str(hp), f"{cid}:{container}"], check=True)
        subprocess.run(
            ["docker", "exec", cid, "chown", "-R",
             f"{os.getuid()}:{os.getgid()}", container],
            check=True,
        )


def copy_out(entries):
    cid = container_id()
    if not cid:
        print("saturn: container not running, skipping copy-out", file=sys.stderr)
        return
    for host, container in entries:
        hp = resolve_host(host)
        hp.parent.mkdir(parents=True, exist_ok=True)
        if hp.exists():
            if hp.is_dir():
                shutil.rmtree(hp)
            else:
                hp.unlink()
        r = subprocess.run(
            ["docker", "cp", f"{cid}:{container}", str(hp)],
        )
        if r.returncode != 0:
            print(f"saturn: copy-out failed for {container}", file=sys.stderr)


def ensure_running():
    if container_id():
        return
    cmd_up(argparse.Namespace(copy=False))


def cmd_up(args):
    mode = "copy" if args.copy else "mount"
    if mode == "mount" and current_level() > 0:
        fail("--mount is not supported inside a nested saturn container; use --copy")
    tag = ensure_base()
    env = runtime_env(tag)
    entries = parse_marker_block(COMPOSE_FILE.read_text(), env)
    compose_run(["up", "-d", "--build", SERVICE_NAME], mode, tag)
    save_mode(mode)
    if mode == "copy":
        copy_in(entries)


def cmd_down(args):
    mode = load_mode() or "mount"
    tag = BASE_HASH_FILE.read_text().strip() if BASE_HASH_FILE.exists() else ""
    if mode == "copy":
        env = runtime_env(tag or "unknown")
        entries = parse_marker_block(COMPOSE_FILE.read_text(), env)
        copy_out(entries)
    compose_run(["down", "--remove-orphans"], mode, tag, check=False)
    clear_mode()


def docker_exec(cmd):
    """Run inside the dev container as guest. Uses `docker exec` (not compose)
    so stdin stays attached for tty — piping the compose YAML via stdin on
    `docker compose exec` would fight the interactive terminal."""
    cid = container_id()
    if not cid:
        fail("container not running")
    subprocess.run(
        ["docker", "exec", "-it",
         "-u", CONTAINER_USER,
         "-e", f"HOME={CONTAINER_HOME}",
         cid, *cmd],
        check=False,
    )


def cmd_shell(args):
    ensure_running()
    docker_exec(["bash"])


def cmd_exec(args):
    if not args.cmd:
        cmd_shell(args)
        return
    ensure_running()
    docker_exec(["bash", "-ic", " ".join(args.cmd)])


def cmd_sync(args):
    mode = load_mode()
    if mode != "copy":
        fail("saturn sync requires a container started with --copy")
    tag = BASE_HASH_FILE.read_text().strip()
    env = runtime_env(tag)
    entries = parse_marker_block(COMPOSE_FILE.read_text(), env)
    direction = args.direction or "both"
    if direction in ("in", "both"):
        copy_in(entries)
    if direction in ("out", "both"):
        copy_out(entries)


def cmd_config(args):
    mode = "copy" if args.copy else "mount"
    print(compose_stdin(mode), end="")


def cmd_status(args):
    cid = container_id()
    mode = load_mode() or "-"
    try:
        env = runtime_env(BASE_HASH_FILE.read_text().strip() if BASE_HASH_FILE.exists() else "")
        entries = parse_marker_block(COMPOSE_FILE.read_text(), env)
    except FileNotFoundError:
        entries = []
    print(f"running: {'yes' if cid else 'no'}")
    print(f"container-id: {cid or '-'}")
    print(f"mode: {mode}")
    print(f"saturn-level: {current_level()}")
    print(f"project-name: {project_name()}")
    print(f"compose-project: {compose_project_name()}")
    print("dual-mode entries:")
    for host, container in entries:
        print(f"  {host} -> {container}")


BASH_COMPLETION = """# bash completion for saturn
_saturn_completion() {
  local cur prev words cword
  COMPREPLY=()
  cur="${COMP_WORDS[COMP_CWORD]}"
  prev="${COMP_WORDS[COMP_CWORD-1]}"
  words=("${COMP_WORDS[@]}")
  cword=$COMP_CWORD
  if [[ $cword -eq 1 ]]; then
    COMPREPLY=($(compgen -W "up down shell exec sync config status help completion" -- "$cur"))
    return 0
  fi
  case "${words[1]}" in
    up|config) COMPREPLY=($(compgen -W "--mount --copy" -- "$cur"));;
    sync)      COMPREPLY=($(compgen -W "in out both" -- "$cur"));;
    completion)COMPREPLY=($(compgen -W "bash" -- "$cur"));;
  esac
}
complete -F _saturn_completion saturn
complete -F _saturn_completion ./dev/saturn
"""


def cmd_completion(args):
    if args.shell != "bash":
        fail(f"unsupported shell: {args.shell}")
    print(BASH_COMPLETION, end="")


def cmd_help(args, parser):
    parser.print_help()


def build_parser():
    p = argparse.ArgumentParser(prog="saturn")
    sub = p.add_subparsers(dest="cmd")

    up = sub.add_parser("up", help="build and start the dev container")
    g = up.add_mutually_exclusive_group()
    g.add_argument("--mount", dest="copy", action="store_false")
    g.add_argument("--copy", dest="copy", action="store_true")
    up.set_defaults(copy=False, func=cmd_up)

    sub.add_parser("down", help="stop and remove the dev container").set_defaults(func=cmd_down)
    sub.add_parser("shell", help="open a shell in the dev container").set_defaults(func=cmd_shell)

    e = sub.add_parser("exec", help="run a command in the dev container")
    e.add_argument("cmd", nargs="*")
    e.set_defaults(func=cmd_exec)

    s = sub.add_parser("sync", help="copy-mode manual sync (in/out/both)")
    s.add_argument("direction", nargs="?", choices=["in", "out", "both"], default="both")
    s.set_defaults(func=cmd_sync)

    c = sub.add_parser("config", help="print transformed compose to stdout")
    g2 = c.add_mutually_exclusive_group()
    g2.add_argument("--mount", dest="copy", action="store_false")
    g2.add_argument("--copy", dest="copy", action="store_true")
    c.set_defaults(copy=False, func=cmd_config)

    sub.add_parser("status", help="print saturn state").set_defaults(func=cmd_status)

    comp = sub.add_parser("completion", help="print shell completion")
    comp.add_argument("shell", nargs="?", default="bash")
    comp.set_defaults(func=cmd_completion)

    sub.add_parser("help", help="show help").set_defaults(func=lambda a: p.print_help())
    return p


def main(argv):
    parser = build_parser()
    args = parser.parse_args(argv[1:])
    if not getattr(args, "func", None):
        parser.print_help()
        return
    args.func(args)


if __name__ == "__main__":
    main(sys.argv)
