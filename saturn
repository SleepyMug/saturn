#!/usr/bin/env python3
"""saturn: minimal per-project dev container CLI (rootless podman/docker).

Each project is a host directory at $HOME/saturn/<name>. Saturn bind-mounts
the projects root and selected mixin paths (subsets of $HOME like ~/.ssh,
~/.claude.json) path-symmetrically into each container; containers run as
root, which rootless userns maps back to your host user — so files written
from inside land on disk with the right ownership.

Works at any nesting level: SATURN_HOST_HOME and SATURN_HOST_SOCK propagate
so `saturn` inside a saturn container creates siblings on the host engine.

Commands:
  base {template,default,build}
    template [--mixins <csv>]      print Containerfile (with setup splices) to stdout
    default  [--mixins <csv>]      (re)build base from inlined default
    build <file>                   (re)build base from a Containerfile (verbatim)

  ls                               list projects
  new <name>                       create $HOME/saturn/<name> + .saturn/Containerfile
  rm <name> [-f]                   stop container, remove image, rm host dir
  up <name>  [--mixins <csv>]      build project image + start container
  down <name>                      stop+remove container (host dir kept)
  shell <name>                     interactive shell in project container
  exec <name> <cmd> [args...]      run command in project container

Mixins (user-global state bundles — tool install + bind-mounted paths):
  Each mixin declares HOME-relative `paths` and a `setup` script. The setup
  is spliced into the base Containerfile as `RUN <setup>`; the paths are
  bind-mounted symmetrically (`-v $HOST_HOME/<rel>:$HOST_HOME/<rel>`) on `up`.
  Missing paths on host cause `up` to fail so the user knows to run
  `ssh-keygen`, `gh auth login`, etc. first.
"""

from __future__ import annotations

import argparse
import os
import shutil
import subprocess
import sys
import tempfile
from pathlib import Path

# ---------- config from env ----------------------------------------------

SCRIPT = Path(__file__).resolve()

BASE_IMAGE = os.environ.get("SATURN_BASE_IMAGE", "localhost/saturn-base:latest")

# The base Containerfile is inlined so the distribution unit is a single
# file. Split into HEAD + TAIL so mixin setup lines splice between the base
# packages layer and the `COPY saturn` step. Containers run as root;
# IS_SANDBOX=1 lets Claude Code accept --dangerously-skip-permissions.
BASE_CONTAINERFILE_HEAD = """\
FROM docker.io/library/debian:trixie-slim

RUN apt-get update \\
 && apt-get install -y --no-install-recommends \\
      docker-cli ca-certificates python3 git \\
 && rm -rf /var/lib/apt/lists/*
"""

BASE_CONTAINERFILE_TAIL = """\
COPY saturn /usr/local/bin/saturn
RUN chmod 0755 /usr/local/bin/saturn

ENV IS_SANDBOX=1

CMD ["sleep", "infinity"]
"""


# ---------- mixins -------------------------------------------------------
#
# Each mixin bundles:
# - `paths`: list of HOME-relative strings. Each resolves to $HOST_HOME/<rel>
#   and is bind-mounted path-symmetrically (`-v <host>:<host>`) on `up`.
#   A missing path on host causes `up` to fail fast.
# - `setup`: shell string spliced into the base Containerfile as `RUN <setup>`
#   during `base default` / `base template`. Empty means no install step.
MIXINS: dict[str, dict] = {
    "ssh": {
        "paths": [".ssh"],
        "setup": (
            "apt-get update"
            " && apt-get install -y --no-install-recommends openssh-client"
            " && rm -rf /var/lib/apt/lists/*"
        ),
    },
    "gh": {
        "paths": [".config/gh"],
        "setup": (
            "apt-get update"
            " && apt-get install -y --no-install-recommends gh"
            " && rm -rf /var/lib/apt/lists/*"
        ),
    },
    "claude": {
        "paths": [".claude", ".claude.json"],
        "setup": (
            "apt-get update"
            " && apt-get install -y --no-install-recommends curl ca-certificates nodejs npm"
            " && npm install -g @anthropic-ai/claude-code"
            " && rm -rf /var/lib/apt/lists/*"
        ),
    },
    "codex": {
        "paths": [".codex"],
        "setup": (
            "apt-get update"
            " && apt-get install -y --no-install-recommends curl ca-certificates nodejs npm"
            " && npm install -g @openai/codex"
            " && rm -rf /var/lib/apt/lists/*"
        ),
    },
}

DEFAULT_MIXINS: list[str] = ["ssh", "claude", "codex", "gh"]


def _parse_mixin_list(spec: str | None) -> list[str]:
    if not spec:
        return []
    names = [s.strip() for s in spec.split(",") if s.strip()]
    unknown = [n for n in names if n not in MIXINS]
    if unknown:
        sys.exit(f"unknown mixin(s): {unknown}  (known: {', '.join(MIXINS)})")
    return names


def _cli_mixins(raw: str | None) -> list[str]:
    # None (flag omitted) → defaults; explicit value (including '') parsed verbatim.
    if raw is None:
        return list(DEFAULT_MIXINS)
    return _parse_mixin_list(raw)


def _render_base_containerfile(mixin_names: list[str]) -> str:
    setup_lines = []
    for n in mixin_names:
        s = MIXINS[n]["setup"].strip()
        if s:
            setup_lines.append(f"RUN {s}")
    block = ""
    if setup_lines:
        block = "\n".join(setup_lines) + "\n\n"
    return BASE_CONTAINERFILE_HEAD + "\n" + block + BASE_CONTAINERFILE_TAIL


# SATURN_ENGINE picks only the default socket path; saturn always shells to
# `docker`. All ops go through the socket so one service process serializes
# store mutations (avoiding rootless-podman store races).
ENGINE = os.environ.get("SATURN_ENGINE", "podman")
if ENGINE not in ("podman", "docker"):
    sys.exit(f"SATURN_ENGINE must be podman or docker (got: {ENGINE})")


def _default_socket() -> str:
    xdg = os.environ.get("XDG_RUNTIME_DIR", f"/run/user/{os.getuid()}")
    return f"{xdg}/podman/podman.sock" if ENGINE == "podman" else f"{xdg}/docker.sock"


SOCK = os.environ.get("SATURN_SOCK", _default_socket())
HOST_SOCK = os.environ.get("SATURN_HOST_SOCK", SOCK)
HOST_HOME = os.environ.get("SATURN_HOST_HOME") or str(Path.home())

os.environ["DOCKER_HOST"] = f"unix://{SOCK}"

# Podman's docker-compat socket doesn't serve BuildKit; force classic builder.
# Docker (including rootless) serves BuildKit and prefers it.
if ENGINE == "podman":
    os.environ["DOCKER_BUILDKIT"] = "0"

sys.stdout.reconfigure(line_buffering=True)


# ---------- engine invocation helpers ------------------------------------

def engine(*args: str) -> None:
    subprocess.run(["docker", *args], check=True)


def engine_quiet(*args: str) -> None:
    subprocess.run(
        ["docker", *args],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        check=True,
    )


def engine_ok(*args: str) -> bool:
    r = subprocess.run(
        ["docker", *args],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )
    return r.returncode == 0


def engine_out(*args: str) -> str | None:
    r = subprocess.run(
        ["docker", *args],
        stdout=subprocess.PIPE,
        stderr=subprocess.DEVNULL,
        text=True,
    )
    return r.stdout.strip() if r.returncode == 0 else None


def engine_exec(*args: str) -> None:
    os.execvp("docker", ["docker", *args])


# ---------- project model ------------------------------------------------

SATURN_ROOT = Path(HOST_HOME) / "saturn"
CONTAINERFILE_REL = ".saturn/Containerfile"

CONTAINERFILE_TEMPLATE = (
    "FROM {base}\n"
    "\n"
    "# Add project tooling here. Example:\n"
    "#   RUN apt-get update \\\n"
    "#    && apt-get install -y --no-install-recommends ripgrep \\\n"
    "#    && rm -rf /var/lib/apt/lists/*\n"
)


class Project:
    def __init__(self, name: str) -> None:
        if not name or "/" in name or name.startswith(".") or " " in name:
            sys.exit(f"invalid project name: {name!r}")
        self.name = name
        self.container = f"saturn_{name}"
        self.image = f"localhost/saturn-{name}:latest"
        self.host_dir = SATURN_ROOT / name

    def containerfile(self) -> Path:
        return self.host_dir / CONTAINERFILE_REL


def project_list() -> list[str]:
    names: set[str] = set()
    # Host-side: any dir with a `.saturn/` marker (created by `saturn new`).
    # Hidden dirs and unrelated subdirs of $HOME/saturn are filtered out.
    if SATURN_ROOT.is_dir():
        for child in SATURN_ROOT.iterdir():
            if child.is_dir() and not child.name.startswith(".") and (child / ".saturn").is_dir():
                names.add(child.name)
    out = engine_out(
        "ps", "-a",
        "--filter", "label=saturn.project",
        "--format", "{{index .Labels \"saturn.project\"}}",
    )
    if out:
        for line in out.splitlines():
            line = line.strip()
            if line:
                names.add(line)
    return sorted(names)


# ---------- base image ---------------------------------------------------

def _build_base(containerfile_text: str) -> None:
    with tempfile.TemporaryDirectory(prefix="saturn-base-") as td:
        tdp = Path(td)
        cf = tdp / "Containerfile"
        cf.write_text(containerfile_text)
        shutil.copy(SCRIPT, tdp / "saturn")
        engine("build", "-f", str(cf), "-t", BASE_IMAGE, td)


def ensure_base() -> None:
    if engine_ok("image", "inspect", BASE_IMAGE):
        return
    print(f"building base image: {BASE_IMAGE} (first time only)")
    _build_base(_render_base_containerfile(DEFAULT_MIXINS))


def check_socket() -> None:
    if not Path(SOCK).is_socket():
        sys.exit(f"engine socket not found at {SOCK}")


# ---------- shared runtime helpers ---------------------------------------

def container_status(name: str) -> str:
    return engine_out("inspect", "-f", "{{.State.Status}}", name) or ""


def _interactive_flags() -> list[str]:
    return ["-it"] if sys.stdin.isatty() else ["-i"]


def _env_flags() -> list[str]:
    # SATURN_HOST_SOCK / SATURN_HOST_HOME carry host-side paths so a nested
    # saturn can reconstruct the right bind-mounts. HOME override makes ~
    # resolve to $HOST_HOME (where mixin paths are mounted).
    return [
        "-e", f"SATURN_ENGINE={ENGINE}",
        "-e", "SATURN_SOCK=/var/run/docker.sock",
        "-e", f"SATURN_HOST_SOCK={HOST_SOCK}",
        "-e", f"SATURN_HOST_HOME={HOST_HOME}",
        "-e", f"HOME={HOST_HOME}",
    ]


def _base_mount_flags() -> list[str]:
    # The projects root is always mounted path-symmetrically so nested saturn
    # can read/write any project. The engine socket lets it talk to the host
    # engine. Nothing else from $HOME comes in automatically — mixins opt-in.
    return [
        "-v", f"{SATURN_ROOT}:{SATURN_ROOT}",
        "-v", f"{HOST_SOCK}:/var/run/docker.sock",
    ]


def _mixin_paths(names: list[str]) -> list[tuple[str, str]]:
    """Return (mixin-name, absolute-host-path) pairs for each path in each mixin."""
    return [(n, f"{HOST_HOME}/{rel}") for n in names for rel in MIXINS[n]["paths"]]


def _check_mixin_paths(names: list[str]) -> None:
    missing = [(n, p) for (n, p) in _mixin_paths(names) if not Path(p).exists()]
    if not missing:
        return
    lines = [f"  {n}: {p}" for (n, p) in missing]
    sys.exit(
        "mixin path(s) missing on host:\n"
        + "\n".join(lines)
        + "\nCreate them (ssh-keygen, gh auth login, claude login, ...) "
          "or drop the mixin from --mixins."
    )


def _mixin_mount_flags(names: list[str]) -> list[str]:
    args: list[str] = []
    for _, p in _mixin_paths(names):
        args += ["-v", f"{p}:{p}"]
    return args


# ---------- commands: base ----------------------------------------------

def cmd_base_template(args: argparse.Namespace) -> None:
    mixins = _cli_mixins(getattr(args, "mixins", None))
    sys.stdout.write(_render_base_containerfile(mixins))


def cmd_base_default(args: argparse.Namespace) -> None:
    mixins = _cli_mixins(getattr(args, "mixins", None))
    engine_ok("rmi", BASE_IMAGE)
    note = f" (mixins: {', '.join(mixins)})" if mixins else " (no mixins)"
    print(f"building base image: {BASE_IMAGE}{note}")
    _build_base(_render_base_containerfile(mixins))
    print(f"base ready: {BASE_IMAGE}")


def cmd_base_build(args: argparse.Namespace) -> None:
    path = Path(args.file)
    if not path.is_file():
        sys.exit(f"Containerfile not found: {path}")
    engine_ok("rmi", BASE_IMAGE)
    print(f"building base image: {BASE_IMAGE} from {path}")
    _build_base(path.read_text())
    print(f"base ready: {BASE_IMAGE}")


# ---------- commands: project lifecycle ---------------------------------

def cmd_ls(_args: argparse.Namespace) -> None:
    for n in project_list():
        print(n)


def cmd_new(args: argparse.Namespace) -> None:
    p = Project(args.name)
    p.host_dir.mkdir(parents=True, exist_ok=True)
    cf = p.containerfile()
    if not cf.exists():
        cf.parent.mkdir(parents=True, exist_ok=True)
        cf.write_text(CONTAINERFILE_TEMPLATE.format(base=BASE_IMAGE))
        seeded = True
    else:
        seeded = False
    print(f"created: {p.host_dir}")
    if seeded:
        print(f"seeded:  {cf}")
    print(f"  next: $EDITOR {cf} && saturn up {p.name}")


def cmd_rm(args: argparse.Namespace) -> None:
    p = Project(args.name)
    has_dir = p.host_dir.exists()
    has_container = container_status(p.container) != ""
    if not has_dir and not has_container:
        sys.exit(f"no such project: {p.name}")
    if not args.force:
        prompt = (
            f"remove container {p.container}, image {p.image}, "
            f"and directory {p.host_dir}?\n"
            f"type project name ({p.name}) to confirm: "
        )
        try:
            ans = input(prompt)
        except EOFError:
            ans = ""
        if ans != p.name:
            sys.exit("aborted")
    engine_ok("rm", "-f", p.container)
    engine_ok("rmi", p.image)
    if has_dir:
        shutil.rmtree(p.host_dir)
    print(f"removed: {p.name}")


# ---------- commands: up/down/shell/exec --------------------------------

def cmd_up(args: argparse.Namespace) -> None:
    p = Project(args.name)
    if not p.host_dir.is_dir():
        sys.exit(f"no such project: {p.name}"
                 f"  (try: saturn new {p.name})")
    mixins = _cli_mixins(getattr(args, "mixins", None))
    _check_mixin_paths(mixins)
    check_socket()
    ensure_base()

    cf = p.containerfile()
    if cf.is_file():
        print(f"building {p.image} from {p.host_dir}...")
        engine("build", "-f", str(cf), "-t", p.image, str(p.host_dir))
        image = p.image
    else:
        print(f"no {CONTAINERFILE_REL}, using {BASE_IMAGE}")
        image = BASE_IMAGE

    status = container_status(p.container)
    if status == "running":
        print(f"already up: {p.container}"
              "  (down && up to pick up image changes)")
        return
    if status:
        engine_ok("rm", "-f", p.container)

    engine_quiet(
        "run", "-d", "--init", "--name", p.container,
        "--label", f"saturn.project={p.name}",
        *_base_mount_flags(),
        *_mixin_mount_flags(mixins),
        *_env_flags(),
        "-w", str(p.host_dir),
        image,
    )
    note = f"  (mixins: {', '.join(mixins)})" if mixins else ""
    print(f"up: {p.container}{note}")


def cmd_down(args: argparse.Namespace) -> None:
    p = Project(args.name)
    engine_ok("rm", "-f", p.container)
    print(f"down: {p.container}")


def cmd_shell(args: argparse.Namespace) -> None:
    p = Project(args.name)
    if container_status(p.container) != "running":
        sys.exit(f"container not running: {p.container}"
                 f"  (try: saturn up {p.name})")
    engine_exec("exec", *_interactive_flags(), p.container, "/bin/bash")


def cmd_exec(args: argparse.Namespace) -> None:
    p = Project(args.name)
    if container_status(p.container) != "running":
        sys.exit(f"container not running: {p.container}"
                 f"  (try: saturn up {p.name})")
    engine_exec("exec", *_interactive_flags(), p.container, *args.cmd)


# ---------- dispatch ----------------------------------------------------

def _mixins_help() -> str:
    return (
        "comma-separated mixin names "
        f"(known: {', '.join(MIXINS)}; "
        f"default: {','.join(DEFAULT_MIXINS)}; pass '' for none)"
    )


def main() -> None:
    # Intercept `exec` before argparse so flags in the user's command survive.
    if len(sys.argv) >= 2 and sys.argv[1] == "exec":
        if len(sys.argv) < 4:
            sys.exit("usage: saturn exec <name> <cmd> [args...]")
        ns = argparse.Namespace(name=sys.argv[2], cmd=sys.argv[3:])
        cmd_exec(ns)
        return

    parser = argparse.ArgumentParser(
        prog="saturn",
        description=__doc__,
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=(
            "env vars:\n"
            "  SATURN_ENGINE       podman|docker -- host engine family (default podman)\n"
            "  SATURN_SOCK         socket path (DOCKER_HOST is derived from this)\n"
            "  SATURN_HOST_SOCK    host-side socket path for nested bind-mounts\n"
            "  SATURN_HOST_HOME    host-side $HOME for nested bind-mounts\n"
            "  SATURN_BASE_IMAGE   default: localhost/saturn-base:latest\n"
        ),
    )
    sub = parser.add_subparsers(dest="command")

    base = sub.add_parser("base", help="base image lifecycle")
    base_sub = base.add_subparsers(dest="subcommand")
    bt = base_sub.add_parser("template", help="print Containerfile to stdout")
    bt.add_argument("--mixins", default=None, help=_mixins_help())
    bt.set_defaults(fn=cmd_base_template)
    bd = base_sub.add_parser("default", help="(re)build base from inlined default")
    bd.add_argument("--mixins", default=None, help=_mixins_help())
    bd.set_defaults(fn=cmd_base_default)
    bb = base_sub.add_parser("build", help="(re)build base from a Containerfile")
    bb.add_argument(
        "file",
        help="path to a Containerfile (must COPY saturn /usr/local/bin/saturn)",
    )
    bb.set_defaults(fn=cmd_base_build)

    sub.add_parser("ls", help="list projects").set_defaults(fn=cmd_ls)

    p_new = sub.add_parser("new", help="create $HOME/saturn/<name> + .saturn/Containerfile")
    p_new.add_argument("name")
    p_new.set_defaults(fn=cmd_new)

    p_rm = sub.add_parser("rm", help="stop container, remove image, rm host dir")
    p_rm.add_argument("name")
    p_rm.add_argument("-f", "--force", action="store_true",
                      help="skip confirmation prompt")
    p_rm.set_defaults(fn=cmd_rm)

    p_up = sub.add_parser("up", help="build project image + start container")
    p_up.add_argument("name")
    p_up.add_argument("--mixins", default=None, help=_mixins_help())
    p_up.set_defaults(fn=cmd_up)

    p_down = sub.add_parser("down", help="stop+remove container (host dir kept)")
    p_down.add_argument("name")
    p_down.set_defaults(fn=cmd_down)

    p_shell = sub.add_parser("shell", help="interactive shell in project container")
    p_shell.add_argument("name")
    p_shell.set_defaults(fn=cmd_shell)

    p_exec = sub.add_parser("exec", help="run command in project container")
    p_exec.add_argument("name")
    p_exec.add_argument("cmd", nargs=argparse.REMAINDER)
    p_exec.set_defaults(fn=cmd_exec)

    args = parser.parse_args()
    fn = getattr(args, "fn", None)
    if fn is None:
        parser.print_help()
        return
    fn(args)


if __name__ == "__main__":
    try:
        main()
    except subprocess.CalledProcessError as e:
        sys.exit(e.returncode)
    except KeyboardInterrupt:
        sys.exit(130)
