#!/usr/bin/env python3
"""saturn: minimal dev-container CLI (rootless podman/docker).

A workspace is any directory containing `.saturn/`. `saturn up [dir]`
bind-mounts that dir at /root/<basename> inside a fresh container; `down`,
`shell`, and `exec` operate on the container for the current cwd's
workspace. Containers run as root, which rootless userns maps back to your
host user — so files written from inside land on disk with host ownership.

Nested `saturn up` works when the target is a subdirectory of the current
container's workspace: saturn derives the host path by appending the
relative path to SATURN_HOST_WORKSPACE.

Commands:
  base {template,default,build}
    template [--mixins <csv>]      print Containerfile (with setup splices) to stdout
    default  [--mixins <csv>]      (re)build base from inlined default
    build <file>                   (re)build base from a Containerfile (verbatim)

  new   [dir]                      create <dir>/.saturn/ + Containerfile (default cwd)
  up    [dir] [--mixins <csv>] [--mixin-root <dir>]
                                   build workspace image + start container
  down                             stop+remove container for cwd's workspace
  shell                            interactive shell in cwd's container
  exec <cmd> [args...]             run command in cwd's container

Mixins (user-global state bundles — tool install + bind-mounted paths):
  Each mixin declares a `setup` script plus one or more `slots`. A slot has
  an `env` (host-path env var), a fixed container `target`, a `kind`
  (file|dir), and a HOME-relative `default_host` fallback. On `saturn up`
  each slot is bind-mounted `<host_path>:<target>`. Host mode resolves
  `host_path` from the env var or falls back to $HOST_HOME/<default_host>,
  creating missing paths automatically. Guest mode (inside a container,
  SATURN_IN_GUEST=1) requires the env var to be set; the outer saturn
  propagates it.
"""

from __future__ import annotations

import argparse
import os
import shutil
import subprocess
import sys
import tempfile
from pathlib import Path

# ---------- config from env ----------------------------------------------

SCRIPT = Path(__file__).resolve()

BASE_IMAGE = os.environ.get("SATURN_BASE_IMAGE", "localhost/saturn-base:latest")

# The base Containerfile is inlined so the distribution unit is a single
# file. Split into HEAD + TAIL so mixin setup lines splice between the base
# packages layer and the `COPY saturn` step. Containers run as root;
# IS_SANDBOX=1 lets Claude Code accept --dangerously-skip-permissions.
BASE_CONTAINERFILE_HEAD = """\
FROM docker.io/library/debian:trixie-slim

RUN apt-get update \\
 && apt-get install -y --no-install-recommends \\
      docker-cli ca-certificates python3 git \\
 && rm -rf /var/lib/apt/lists/*
"""

BASE_CONTAINERFILE_TAIL = """\
COPY saturn /usr/local/bin/saturn
RUN chmod 0755 /usr/local/bin/saturn

ENV IS_SANDBOX=1

CMD ["sleep", "infinity"]
"""


# ---------- mixins -------------------------------------------------------
#
# Each mixin bundles:
# - `slots`: list of per-path records. Each slot is bind-mounted as
#   `<host_path>:<target>` on `up`. `host_path` comes from `env` (a dedicated
#   env var) or — in host mode only — from $HOST_HOME/<default_host>. `kind`
#   ("file" | "dir") tells host-mode auto-create how to materialize a
#   missing path. `target` is the fixed container-side path; the container's
#   tools expect to find the mount there (e.g. /root/.ssh).
# - `setup`: shell string spliced into the base Containerfile as `RUN <setup>`
#   during `base default` / `base template`. Empty means no install step.
MIXINS: dict[str, dict] = {
    "ssh": {
        "slots": [
            {"env": "SATURN_MIXIN_SSH", "target": "/root/.ssh", "kind": "dir", "default_host": ".ssh"},
        ],
        "setup": (
            "apt-get update"
            " && apt-get install -y --no-install-recommends openssh-client"
            " && rm -rf /var/lib/apt/lists/*"
        ),
    },
    "gh": {
        "slots": [
            {"env": "SATURN_MIXIN_GH", "target": "/root/.config/gh", "kind": "dir", "default_host": ".config/gh"},
        ],
        "setup": (
            "apt-get update"
            " && apt-get install -y --no-install-recommends gh"
            " && rm -rf /var/lib/apt/lists/*"
        ),
    },
    "claude": {
        "slots": [
            {"env": "SATURN_MIXIN_CLAUDE", "target": "/root/.claude", "kind": "dir", "default_host": ".claude"},
            {"env": "SATURN_MIXIN_CLAUDE_JSON", "target": "/root/.claude.json", "kind": "file", "default_host": ".claude.json"},
        ],
        "setup": (
            "apt-get update"
            " && apt-get install -y --no-install-recommends curl ca-certificates nodejs npm"
            " && npm install -g @anthropic-ai/claude-code"
            " && rm -rf /var/lib/apt/lists/*"
        ),
    },
    "codex": {
        "slots": [
            {"env": "SATURN_MIXIN_CODEX", "target": "/root/.codex", "kind": "dir", "default_host": ".codex"},
        ],
        "setup": (
            "apt-get update"
            " && apt-get install -y --no-install-recommends curl ca-certificates nodejs npm"
            " && npm install -g @openai/codex"
            " && rm -rf /var/lib/apt/lists/*"
        ),
    },
}

DEFAULT_MIXINS: list[str] = ["ssh", "claude", "codex", "gh"]


def _parse_mixin_list(spec: str | None) -> list[str]:
    if not spec:
        return []
    names = [s.strip() for s in spec.split(",") if s.strip()]
    unknown = [n for n in names if n not in MIXINS]
    if unknown:
        sys.exit(f"unknown mixin(s): {unknown}  (known: {', '.join(MIXINS)})")
    return names


def _cli_mixins(raw: str | None) -> list[str]:
    # None (flag omitted) → defaults; explicit value (including '') parsed verbatim.
    if raw is None:
        return list(DEFAULT_MIXINS)
    return _parse_mixin_list(raw)


def _render_base_containerfile(mixin_names: list[str]) -> str:
    setup_lines = []
    for n in mixin_names:
        s = MIXINS[n]["setup"].strip()
        if s:
            setup_lines.append(f"RUN {s}")
    block = ""
    if setup_lines:
        block = "\n".join(setup_lines) + "\n\n"
    return BASE_CONTAINERFILE_HEAD + "\n" + block + BASE_CONTAINERFILE_TAIL


# SATURN_ENGINE picks only the default socket path; saturn always shells to
# `docker`. All ops go through the socket so one service process serializes
# store mutations (avoiding rootless-podman store races).
ENGINE = os.environ.get("SATURN_ENGINE", "podman")
if ENGINE not in ("podman", "docker"):
    sys.exit(f"SATURN_ENGINE must be podman or docker (got: {ENGINE})")


def _default_socket() -> str:
    xdg = os.environ.get("XDG_RUNTIME_DIR", f"/run/user/{os.getuid()}")
    return f"{xdg}/podman/podman.sock" if ENGINE == "podman" else f"{xdg}/docker.sock"


SOCK = os.environ.get("SATURN_SOCK", _default_socket())
HOST_SOCK = os.environ.get("SATURN_HOST_SOCK", SOCK)
HOST_HOME = os.environ.get("SATURN_HOST_HOME") or str(Path.home())

# Outer saturn sets SATURN_IN_GUEST=1 when launching a child container, so
# inside we know to require per-slot env vars (the outer already resolved
# them) rather than falling back to host-side defaults or creating paths.
IS_HOST = os.environ.get("SATURN_IN_GUEST") != "1"

# Set by the outer saturn when launching a container. HOST_WORKSPACE is the
# host-side absolute path of the current container's workspace; WORKSPACE is
# the container-side absolute path (where the bind-mount lands, e.g.
# /root/<name>). Inner saturn consumes both to translate a target dir into
# a host path for nested bind-mounts.
HOST_WORKSPACE = os.environ.get("SATURN_HOST_WORKSPACE")
WORKSPACE = os.environ.get("SATURN_WORKSPACE")

os.environ["DOCKER_HOST"] = f"unix://{SOCK}"

# Podman's docker-compat socket doesn't serve BuildKit; force classic builder.
# Docker (including rootless) serves BuildKit and prefers it.
if ENGINE == "podman":
    os.environ["DOCKER_BUILDKIT"] = "0"

sys.stdout.reconfigure(line_buffering=True)


# ---------- engine invocation helpers ------------------------------------

def engine(*args: str) -> None:
    subprocess.run(["docker", *args], check=True)


def engine_ok(*args: str) -> bool:
    r = subprocess.run(
        ["docker", *args],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )
    return r.returncode == 0


def engine_out(*args: str) -> str | None:
    r = subprocess.run(
        ["docker", *args],
        stdout=subprocess.PIPE,
        stderr=subprocess.DEVNULL,
        text=True,
    )
    return r.stdout.strip() if r.returncode == 0 else None


def engine_exec(*args: str) -> None:
    os.execvp("docker", ["docker", *args])


# ---------- workspace model ----------------------------------------------

CONTAINERFILE_TEMPLATE = (
    "FROM {base}\n"
    "\n"
    "# Add workspace tooling here. Example:\n"
    "#   RUN apt-get update \\\n"
    "#    && apt-get install -y --no-install-recommends ripgrep \\\n"
    "#    && rm -rf /var/lib/apt/lists/*\n"
)


class Workspace:
    """A directory the user targets for `saturn up`.

    `host_path` is the host-absolute path (docker daemon resolves on host, so
    every `-v <src>:<dst>` source and every `docker build` path uses this).
    `view_path` is the path visible from this saturn process — equal to
    `host_path` on the host, a container-side path inside a container.
    Filesystem checks (is_dir, is_file, mkdir) must use `view_path`.
    """

    def __init__(self, host_path: Path, view_path: Path) -> None:
        name = host_path.name
        if not name or "/" in name or name.startswith(".") or " " in name:
            sys.exit(f"invalid workspace basename: {name!r}  (from path {host_path})")
        self.host_path = host_path
        self.view_path = view_path
        self.name = name
        self.container = f"saturn_{name}"
        self.image = f"localhost/saturn-{name}:latest"
        self.container_dir = Path("/root") / name

    def containerfile_view(self) -> Path:
        return self.view_path / ".saturn" / "Containerfile"

    def containerfile_host(self) -> Path:
        return self.host_path / ".saturn" / "Containerfile"


def _resolve_target(arg: str | None) -> Workspace:
    """Resolve a CLI target (or cwd) to a Workspace.

    Host mode: `host_path == view_path == resolve(arg or '.')`.
    Guest mode: the target must be under the current container's workspace
    (`SATURN_WORKSPACE`); the host path is `SATURN_HOST_WORKSPACE` + the
    relative path from the current workspace to the target. This makes
    nested `up` deterministic without needing to mount the host-side
    projects root.
    """
    view = Path(arg if arg is not None else ".").resolve()
    if not view.is_dir():
        sys.exit(f"not a directory: {view}")
    if IS_HOST:
        return Workspace(host_path=view, view_path=view)
    if not HOST_WORKSPACE or not WORKSPACE:
        sys.exit(
            "SATURN_HOST_WORKSPACE / SATURN_WORKSPACE unset inside container — "
            "can't derive host path for target"
        )
    current = Path(WORKSPACE).resolve()
    try:
        rel = view.relative_to(current)
    except ValueError:
        sys.exit(f"target must be under current workspace {current}: got {view}")
    host = Path(HOST_WORKSPACE) / rel
    return Workspace(host_path=host, view_path=view)


# ---------- base image ---------------------------------------------------

def _build_base(containerfile_text: str) -> None:
    with tempfile.TemporaryDirectory(prefix="saturn-base-") as td:
        tdp = Path(td)
        cf = tdp / "Containerfile"
        cf.write_text(containerfile_text)
        shutil.copy(SCRIPT, tdp / "saturn")
        engine("build", "-f", str(cf), "-t", BASE_IMAGE, td)


def ensure_base() -> None:
    if engine_ok("image", "inspect", BASE_IMAGE):
        return
    print(f"building base image: {BASE_IMAGE} (first time only)")
    _build_base(_render_base_containerfile(DEFAULT_MIXINS))


def check_socket() -> None:
    if not Path(SOCK).is_socket():
        sys.exit(f"engine socket not found at {SOCK}")


# ---------- shared runtime helpers ---------------------------------------

def container_status(name: str) -> str:
    return engine_out("inspect", "-f", "{{.State.Status}}", name) or ""


def _interactive_flags() -> list[str]:
    return ["-it"] if sys.stdin.isatty() else ["-i"]


def _env_flags(slots: list[dict], workspace: Workspace) -> list[str]:
    # SATURN_HOST_SOCK / SATURN_HOST_HOME carry host-side paths for nested
    # saturn. SATURN_HOST_WORKSPACE + SATURN_WORKSPACE are consumed by inner
    # saturn's _resolve_target to translate a target dir under the current
    # workspace into a host path. SATURN_IN_GUEST=1 flips inner saturn into
    # guest mode. Each slot's host-path env var is propagated so inner
    # saturn re-mounts from the real host path.
    flags = [
        "-e", f"SATURN_ENGINE={ENGINE}",
        "-e", "SATURN_SOCK=/var/run/docker.sock",
        "-e", f"SATURN_HOST_SOCK={HOST_SOCK}",
        "-e", f"SATURN_HOST_HOME={HOST_HOME}",
        "-e", "SATURN_IN_GUEST=1",
        "-e", f"SATURN_HOST_WORKSPACE={workspace.host_path}",
        "-e", f"SATURN_WORKSPACE={workspace.container_dir}",
    ]
    for s in slots:
        flags += ["-e", f"{s['env']}={s['host_path']}"]
    return flags


def _base_mount_flags() -> list[str]:
    # Only the engine socket is always present. The per-project workspace
    # mount is added in cmd_up (target `/root/<name>`, no path symmetry);
    # mixin mounts are added per `--mixins` selection. Nothing else from
    # `$HOME` comes in automatically.
    return [
        "-v", f"{HOST_SOCK}:/var/run/docker.sock",
    ]


def _resolve_mixin_slots(names: list[str], mixin_root: str | None = None) -> list[dict]:
    """Return a resolved slot record per slot across the selected mixins.

    Each record carries {mixin, env, target, kind, host_path}. In guest mode,
    `env` must be set — otherwise we exit with a labelled list. In host mode,
    a missing `env` falls back to `<mixin_root>/<default_host>` (or
    `$HOST_HOME/<default_host>` when `mixin_root` is None). Per-slot env var
    overrides still win; `mixin_root` only shifts the default provider.
    """
    root = mixin_root if mixin_root is not None else HOST_HOME
    out: list[dict] = []
    missing_env: list[tuple[str, str]] = []
    for n in names:
        for s in MIXINS[n]["slots"]:
            host_path = os.environ.get(s["env"])
            if host_path is None:
                if IS_HOST:
                    host_path = f"{root}/{s['default_host']}"
                else:
                    missing_env.append((n, s["env"]))
                    continue
            out.append({
                "mixin": n,
                "env": s["env"],
                "target": s["target"],
                "kind": s["kind"],
                "host_path": host_path,
            })
    if missing_env:
        lines = [f"  {n}: {e}" for (n, e) in missing_env]
        sys.exit(
            "mixin env var(s) unset inside container:\n"
            + "\n".join(lines)
            + "\nThe outer saturn should have propagated these. Re-run the "
              "outer `saturn up` with the mixin enabled, or drop it from --mixins."
        )
    return out


def _ensure_mixin_host_paths(slots: list[dict]) -> None:
    """Host-mode: materialize any missing slot host paths (file or dir)."""
    for s in slots:
        p = Path(s["host_path"])
        if p.exists():
            continue
        if s["kind"] == "dir":
            p.mkdir(parents=True, exist_ok=True)
        else:
            p.parent.mkdir(parents=True, exist_ok=True)
            p.touch()
        print(f"created {s['kind']}: {p}  (mixin: {s['mixin']})")


def _mixin_mount_flags(slots: list[dict]) -> list[str]:
    args: list[str] = []
    for s in slots:
        args += ["-v", f"{s['host_path']}:{s['target']}"]
    return args


# ---------- commands: base ----------------------------------------------

def cmd_base_template(args: argparse.Namespace) -> None:
    mixins = _cli_mixins(getattr(args, "mixins", None))
    sys.stdout.write(_render_base_containerfile(mixins))


def cmd_base_default(args: argparse.Namespace) -> None:
    mixins = _cli_mixins(getattr(args, "mixins", None))
    engine_ok("rmi", BASE_IMAGE)
    note = f" (mixins: {', '.join(mixins)})" if mixins else " (no mixins)"
    print(f"building base image: {BASE_IMAGE}{note}")
    _build_base(_render_base_containerfile(mixins))
    print(f"base ready: {BASE_IMAGE}")


def cmd_base_build(args: argparse.Namespace) -> None:
    path = Path(args.file)
    if not path.is_file():
        sys.exit(f"Containerfile not found: {path}")
    engine_ok("rmi", BASE_IMAGE)
    print(f"building base image: {BASE_IMAGE} from {path}")
    _build_base(path.read_text())
    print(f"base ready: {BASE_IMAGE}")


# ---------- commands: workspace lifecycle -------------------------------

def cmd_new(args: argparse.Namespace) -> None:
    raw = getattr(args, "target", None)
    view = Path(raw if raw is not None else ".").resolve()
    view.mkdir(parents=True, exist_ok=True)
    ws = _resolve_target(str(view))
    saturn_dir = ws.view_path / ".saturn"
    saturn_dir.mkdir(parents=True, exist_ok=True)
    cf = saturn_dir / "Containerfile"
    seeded = not cf.exists()
    if seeded:
        cf.write_text(CONTAINERFILE_TEMPLATE.format(base=BASE_IMAGE))
    print(f"workspace: {ws.view_path}")
    if seeded:
        print(f"seeded:    {cf}")
    print(f"  next: $EDITOR {cf} && saturn up {ws.view_path}")


def cmd_up(args: argparse.Namespace) -> None:
    ws = _resolve_target(getattr(args, "target", None))
    check_socket()

    status = container_status(ws.container)
    if status == "running":
        print(f"already up: {ws.container}  (down && up to pick up image changes)")
        return

    mixins = _cli_mixins(getattr(args, "mixins", None))
    mixin_root = getattr(args, "mixin_root", None) if IS_HOST else None
    slots = _resolve_mixin_slots(mixins, mixin_root)
    if IS_HOST:
        _ensure_mixin_host_paths(slots)
    ensure_base()

    cf_view = ws.containerfile_view()
    if cf_view.is_file():
        print(f"building {ws.image} from {ws.host_path}...")
        engine("build", "-f", str(ws.containerfile_host()), "-t", ws.image, str(ws.host_path))
        image = ws.image
    else:
        print(f"no .saturn/Containerfile, using {BASE_IMAGE}")
        image = BASE_IMAGE

    if status:
        engine_ok("rm", "-f", ws.container)

    engine(
        "run", "-d", "--init", "--name", ws.container,
        "--label", f"saturn.workspace={ws.host_path}",
        *_base_mount_flags(),
        "-v", f"{ws.host_path}:{ws.container_dir}",
        *_mixin_mount_flags(slots),
        *_env_flags(slots, ws),
        "-w", str(ws.container_dir),
        image,
    )
    note = f"  (mixins: {', '.join(mixins)})" if mixins else ""
    print(f"up: {ws.container}{note}")


def cmd_down(_args: argparse.Namespace) -> None:
    ws = _resolve_target(None)
    engine_ok("rm", "-f", ws.container)
    print(f"down: {ws.container}")


def cmd_shell(_args: argparse.Namespace) -> None:
    ws = _resolve_target(None)
    if container_status(ws.container) != "running":
        sys.exit(f"container not running: {ws.container}  (try: saturn up)")
    engine_exec("exec", *_interactive_flags(), ws.container, "/bin/bash")


def cmd_exec(args: argparse.Namespace) -> None:
    ws = _resolve_target(None)
    if container_status(ws.container) != "running":
        sys.exit(f"container not running: {ws.container}  (try: saturn up)")
    engine_exec("exec", *_interactive_flags(), ws.container, *args.cmd)


# ---------- dispatch ----------------------------------------------------

def _mixins_help() -> str:
    return (
        "comma-separated mixin names "
        f"(known: {', '.join(MIXINS)}; "
        f"default: {','.join(DEFAULT_MIXINS)}; pass '' for none)"
    )


def main() -> None:
    # Intercept `exec` before argparse so flags in the user's command survive.
    if len(sys.argv) >= 2 and sys.argv[1] == "exec":
        if len(sys.argv) < 3:
            sys.exit("usage: saturn exec <cmd> [args...]")
        ns = argparse.Namespace(cmd=sys.argv[2:])
        cmd_exec(ns)
        return

    parser = argparse.ArgumentParser(
        prog="saturn",
        description=__doc__,
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=(
            "env vars:\n"
            "  SATURN_ENGINE          podman|docker -- host engine family (default podman)\n"
            "  SATURN_SOCK            socket path (DOCKER_HOST is derived from this)\n"
            "  SATURN_HOST_SOCK       host-side socket path for nested bind-mounts\n"
            "  SATURN_HOST_HOME       host-side $HOME (used for mixin defaults)\n"
            "  SATURN_HOST_WORKSPACE  host-side path of the current workspace (set by outer saturn)\n"
            "  SATURN_WORKSPACE       container-side path of the current workspace (set by outer saturn)\n"
            "  SATURN_IN_GUEST        set by outer saturn; presence => inside a container\n"
            "  SATURN_MIXIN_<SLOT>    host-side path for a mixin slot (overrides default)\n"
            "  SATURN_BASE_IMAGE      default: localhost/saturn-base:latest\n"
        ),
    )
    sub = parser.add_subparsers(dest="command")

    base = sub.add_parser("base", help="base image lifecycle")
    base_sub = base.add_subparsers(dest="subcommand")
    bt = base_sub.add_parser("template", help="print Containerfile to stdout")
    bt.add_argument("--mixins", default=None, help=_mixins_help())
    bt.set_defaults(fn=cmd_base_template)
    bd = base_sub.add_parser("default", help="(re)build base from inlined default")
    bd.add_argument("--mixins", default=None, help=_mixins_help())
    bd.set_defaults(fn=cmd_base_default)
    bb = base_sub.add_parser("build", help="(re)build base from a Containerfile")
    bb.add_argument(
        "file",
        help="path to a Containerfile (must COPY saturn /usr/local/bin/saturn)",
    )
    bb.set_defaults(fn=cmd_base_build)

    p_new = sub.add_parser("new", help="create <dir>/.saturn/ + Containerfile (default cwd)")
    p_new.add_argument("target", nargs="?", default=None,
                       help="target directory (default: cwd)")
    p_new.set_defaults(fn=cmd_new)

    p_up = sub.add_parser("up", help="build workspace image + start container")
    p_up.add_argument("target", nargs="?", default=None,
                      help="target directory (default: cwd)")
    p_up.add_argument("--mixins", default=None, help=_mixins_help())
    p_up.add_argument(
        "--mixin-root",
        default=None,
        help="host directory to resolve mixin default paths under "
             "(instead of $HOST_HOME); host mode only; per-slot "
             "SATURN_MIXIN_* env vars still override",
    )
    p_up.set_defaults(fn=cmd_up)

    sub.add_parser("down", help="stop+remove container for cwd's workspace").set_defaults(fn=cmd_down)
    sub.add_parser("shell", help="interactive shell in cwd's container").set_defaults(fn=cmd_shell)

    p_exec = sub.add_parser("exec", help="run command in cwd's container")
    p_exec.add_argument("cmd", nargs=argparse.REMAINDER)
    p_exec.set_defaults(fn=cmd_exec)

    args = parser.parse_args()
    fn = getattr(args, "fn", None)
    if fn is None:
        parser.print_help()
        return
    fn(args)


if __name__ == "__main__":
    try:
        main()
    except subprocess.CalledProcessError as e:
        sys.exit(e.returncode)
    except KeyboardInterrupt:
        sys.exit(130)
